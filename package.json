{
  "name": "cloudy",
  "version": "1.0.0",
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "biome": "^0.3.3",
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun run --title='Bun Monorepo' --filter '*' dev",
    "dev:server": "NODE_ENV=development bun run --filter @cloudy/server dev",
    "dev:web-app": "NODE_ENV=development bun run --filter @cloudy/web-app dev",
    "----LINT----": "",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write .",
    "----CLEAN----": "",
    "clean:modules": "bash -lc 'find . -type d -name node_modules -prune -print -exec rm -rf {} \\; && rm -f bun.lock'"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      ".opencode/*"
    ],
    "catalog": {
      "elysia": "^1.4.28"
    }
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  }
}
