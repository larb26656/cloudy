{
  "name": "cloudy",
  "version": "1.0.0",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.5.2",
    "biome": "^0.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun run --title='Bun Monorepo' --filter @cloudy/server --filter @cloudy/web-app dev",
    "dev:server": "NODE_ENV=development bun run --filter @cloudy/server dev",
    "dev:web-app": "NODE_ENV=development bun run --filter @cloudy/web-app dev",
    "----LINT----": "",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write .",
    "---CHANGE-LOG----": "",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "---CREATE-CLOUDY---": "",
    "dev:create-cloudy": "rm -rf packages/create-cloudy/.test-output && bun run packages/create-cloudy/src/index.ts --dir=packages/create-cloudy/.test-output",
    "test:create-cloudy": "bun run --filter create-cloudy test:cli",
    "----CLOUDY-CLI----": "",
    "cloudy:serve": "bun run apps/server/src/cli.ts serve --config=apps/server/config --dataDir=apps/server/config/data",
    "cloudy:serve:ui": "bun run apps/server/src/cli.ts serve --config=apps/server/config --dataDir=apps/server/config/data --ui",
    "cloudy:build": "bun run scripts/build-frontend.sh",
    "----CI----": "",
    "publish:opencode-plugin": "npm publish --workspace packages/opencode-plugin",
    "publish:create-cloudy": "npm publish --workspace packages/create-cloudy",
    "----CLEAN----": ""
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "elysia": "^1.4.28"
    }
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  }
}
