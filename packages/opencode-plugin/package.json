      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "cloudy",
    "idea",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.2.23",
    "@types/bun": "^1.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
