{
  "name": "@cloudy-app/opencode-plugin",
  "version": "0.0.3",
  "description": "OpenCode plugin for Cloudy — idea management tools and session tracking",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
