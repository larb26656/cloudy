{
  "name": "@cloudy/desktop",
  "version": "0.0.0",
  "author": "luckytime1996",
  "main": "dist-electron/main/index.js",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.cloudy.desktop",
    "productName": "Cloudy",
    "directories": {
      "output": "release-builds"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis"
    }
  },
  "description": "-",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && bunx electron .",
    "build": "rm -rf release-builds && tsc -p tsconfig.main.json && electron-builder",
    "start": "electron ."
  },
  "type": "module",
  "dependencies": {
    "fix-path": "^5.0.0",
    "tree-kill": "^1.2.2"
  }
}
